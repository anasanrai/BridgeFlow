# BridgeFlow Enterprise docker-compose overrides

# This template serves as a quickstart for creating local `.env.local` files for Docker.
# Copy this to `.env.local` and substitute your production values to run the `docker-compose.yml` stack properly.

NEXT_PUBLIC_SUPABASE_URL="https://[PROJECT-ID].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="ey..."

JWT_SECRET="generate-a-long-secure-random-string-here"
ADMIN_PASSWORD="your-strong-admin-password"

UPSTASH_REDIS_REST_URL="https://[YOUR-UPSTASH-URL]"
UPSTASH_REDIS_REST_TOKEN="[YOUR-UPSTASH-TOKEN]"
