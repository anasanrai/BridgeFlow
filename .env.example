# BridgeFlow SaaS Platform — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NODE_ENV=development

# ── Supabase ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Admin Authentication ───────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_min_32_chars
ADMIN_PASSWORD=your_secure_admin_password

# ── Rate Limiting (Upstash Redis) ─────────────────────────────────────────────
# Get from https://console.upstash.com
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ── Payments — Stripe ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_...

# ── Payments — PayPal ─────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox

# ── Payments — Moyasar ────────────────────────────────────────────────────────
MOYASAR_SECRET_KEY=sk_...
NEXT_PUBLIC_MOYASAR_PUBLISHABLE_KEY=pk_...

# ── AI Providers ──────────────────────────────────────────────────────────────
# Primary: OpenRouter (300+ models via single API key)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Secondary: Gemini (direct Google API)
GEMINI_API_KEY=your_gemini_key

# Fallback providers (optional)
MODAL_API_KEY=your_modal_key
OLLAMA_API_KEY=your_ollama_key
REPLICATE_API_TOKEN=your_replicate_token

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=hello@bridgeflow.agency
SMTP_PASS=your_smtp_password
FROM_EMAIL=hello@bridgeflow.agency

# ── Notifications — Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
TELEGRAM_CHAT_ID=your_chat_id

# ── Webhooks ──────────────────────────────────────────────────────────────────
N8N_WEBHOOK_URL=https://your-n8n.domain.com/webhook/bridgeflow
WEBHOOK_SIGNING_SECRET=your_webhook_hmac_secret

# ── SEO & Analytics ───────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_verification_token

# ── Newsletter ────────────────────────────────────────────────────────────────
NEWSLETTER_API_KEY=your_newsletter_api_key
NEWSLETTER_API_URL=https://your-newsletter-service.com/api/subscribe
