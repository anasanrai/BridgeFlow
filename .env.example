# ============================================================
# BridgeFlow — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- PayPal ---
# Get from: https://developer.paypal.com/dashboard/
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox   # Change to "live" for production
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id   # Same as above, needed client-side

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.bridgeflow.agency   # No trailing slash

# --- Telegram (EZRA system) ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# --- Email (Resend) ---
# Get from: https://resend.com/
# Set up domain: hello@bridgeflow.agency
RESEND_API_KEY=re_your-resend-api-key

# ============================================================
# OPTIONAL — Only needed for specific features
# ============================================================

# Calendly embed URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/raianasan10/30min
